<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AstroCode | AI Agent Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        body {
            background: radial-gradient(circle at top right, #1e293b, #020617);
            min-height: 100vh;
            color: #f8fafc;
            font-family: 'Inter', sans-serif;
        }
        .glass {
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
        }
        .neon-border {
            border-bottom: 2px solid #deff9a;
            box-shadow: 0 4px 15px -5px rgba(222, 255, 154, 0.5);
        }
        .status-badge {
            padding: 2px 10px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
        }
        .status-active { background: rgba(34, 197, 94, 0.2); color: #4ade80; }
        .status-processing { background: rgba(59, 130, 246, 0.2); color: #60a5fa; }
    </style>
</head>
<body class="p-6">

    <header class="max-w-6xl mx-auto flex justify-between items-center mb-10">
        <div>
            <h1 class="text-4xl font-bold tracking-tight text-white">ASTRO<span class="text-[#deff9a]">CODE</span></h1>
            <p class="text-gray-400">AMD Accelerated Agentic Workflows</p>
        </div>
        <div class="glass p-4 rounded-xl flex items-center gap-4">
            <div class="text-right">
                <p class="text-xs text-gray-400 uppercase">System Status</p>
                <p class="text-sm font-semibold text-[#deff9a]">ROCm 7.0 Active</p>
            </div>
            <i class="fa-solid fa-microchip text-2xl text-[#deff9a]"></i>
        </div>
    </header>

    <main class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <section class="lg:col-span-1 space-y-6">
            <div class="glass p-6 rounded-2xl">
                <h2 class="text-xl font-semibold mb-4 flex items-center gap-2">
                    <i class="fa-solid fa-terminal text-[#00f2ff]"></i> Command Center
                </h2>
                <form action="/api/tasks" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-sm text-gray-400 mb-1">Task Title</label>
                        <input type="text" name="title" class="w-full bg-slate-900 border border-slate-700 rounded-lg p-2.5 focus:outline-none focus:border-[#deff9a]" placeholder="e.g. Market Analysis">
                    </div>
                    <div>
                        <label class="block text-sm text-gray-400 mb-1">Prompt / Payload</label>
                        <textarea name="payload" rows="4" class="w-full bg-slate-900 border border-slate-700 rounded-lg p-2.5 focus:outline-none focus:border-[#deff9a]" placeholder="Describe what the agent should do..."></textarea>
                    </div>
                    <button type="submit" class="w-full bg-[#deff9a] text-black font-bold py-3 rounded-lg hover:bg-[#c4e67d] transition-all flex justify-center items-center gap-2">
                        <i class="fa-solid fa-rocket"></i> Launch Agent
                    </button>
                </form>
            </div>
        </section>

        <section class="lg:col-span-2 space-y-6">
            <div class="glass p-6 rounded-2xl">
                <h2 class="text-xl font-semibold mb-4 flex justify-between items-center">
                    <span><i class="fa-solid fa-satellite-dish text-[#deff9a] mr-2"></i>Active Agents</span>
                    <span class="text-xs bg-slate-800 px-3 py-1 rounded-full text-gray-300">Live Feed</span>
                </h2>
                
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="text-gray-400 text-sm border-b border-slate-800">
                                <th class="pb-3">Agent Name</th>
                                <th class="pb-3">Last Task</th>
                                <th class="pb-3 text-right">Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-800">
                            <% agents.forEach(agent => { %>
                            <tr>
                                <td class="py-4">
                                    <div class="font-medium text-white"><%= agent.name %></div>
                                    <div class="text-xs text-gray-500"><%= agent.type %></div>
                                </td>
                                <td class="py-4 text-sm text-gray-300">
                                    <%= agent.Tasks.length > 0 ? agent.Tasks[0].title : 'No tasks assigned' %>
                                </td>
                                <td class="py-4 text-right">
                                    <span class="status-badge status-active"><%= agent.status %></span>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

    </main>

    <footer class="max-w-6xl mx-auto mt-12 grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="glass p-4 rounded-xl text-center">
            <p class="text-xs text-gray-500 uppercase">GPU Load</p>
            <p class="text-xl font-bold">42%</p>
        </div>
        <div class="glass p-4 rounded-xl text-center">
            <p class="text-xs text-gray-500 uppercase">Tokens/sec</p>
            <p class="text-xl font-bold text-[#deff9a]">128.5</p>
        </div>
        <div class="glass p-4 rounded-xl text-center">
            <p class="text-xs text-gray-500 uppercase">Inference Time</p>
            <p class="text-xl font-bold">0.8s</p>
        </div>
        <div class="glass p-4 rounded-xl text-center">
            <p class="text-xs text-gray-500 uppercase">Model</p>
            <p class="text-xl font-bold">Qwen 2.5</p>
        </div>
    </footer>

</body>
</html>